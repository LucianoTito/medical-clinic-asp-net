# Normalización automática de finales de línea.
# Git guarda LF internamente; el árbol de trabajo respeta las reglas de abajo.
* text=auto

# Archivos de Visual Studio / .NET: siempre CRLF en el working tree
*.cs      text eol=crlf
*.aspx    text eol=crlf
*.ascx    text eol=crlf
*.Master  text eol=crlf
*.master  text eol=crlf
*.config  text eol=crlf
*.slnx    text eol=crlf
*.csproj  text eol=crlf
*.sql     text eol=crlf

# Web
*.css     text eol=crlf
*.js      text eol=crlf
*.md      text eol=crlf

# Binarios: Git no debe tocarlos nunca
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.dll     binary
*.pdf     binary
